{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "!node_modules/**"
        ]
      }
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 800
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/broadcast-whatsapp",
      "schedule": "0 11 15,30 * *"
    }
  ]
}
