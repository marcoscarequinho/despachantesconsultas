{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,*.css,*.js,*.txt,*.xml,*.ico,*.png}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/broadcast-whatsapp",
      "schedule": "0 11 15,30 * *"
    },
    {
      "path": "/api/cron/crlv-agendado-status",
      "schedule": "*/15 * * * *"
    }
  ]
}
